{
  "name": "headless-basic",
  "cases": [
    {
      "name": "plain ascii",
      "options": {
        "allowProposedApi": true,
        "cols": 10,
        "rows": 3
      },
      "writes": [
        "foo"
      ]
    },
    {
      "name": "carriage return and line feed",
      "options": {
        "allowProposedApi": true,
        "cols": 5,
        "rows": 3
      },
      "writes": [
        "foo\r\nbar"
      ]
    },
    {
      "name": "backspace overwrites",
      "options": {
        "allowProposedApi": true,
        "cols": 5,
        "rows": 3
      },
      "writes": [
        "ab\bC"
      ]
    },
    {
      "name": "basic wrap",
      "options": {
        "allowProposedApi": true,
        "cols": 3,
        "rows": 2
      },
      "writes": [
        "abcde"
      ]
    },
    {
      "name": "bottom row scroll",
      "options": {
        "allowProposedApi": true,
        "cols": 8,
        "rows": 3,
        "scrollback": 10
      },
      "writes": [
        "one\r\ntwo\r\nthree\r\nfour"
      ]
    }
  ]
}
